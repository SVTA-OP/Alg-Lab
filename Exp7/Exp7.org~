** 4. Implement Gayle-Shapeley algorithm to find a stable matching.

#+begin_src python :results output :session Exp7
def gale_shapley(men, women):
    free_men = [m[0] for m in men]

    def prefers(w, new_m, current_m):
        prefs = next(woman[1] for woman in women if woman[0] == w)
        return prefs.index(new_m) < prefs.index(current_m)

    while free_men:
        m = free_men[0]
        m_idx = next(i for i, man in enumerate(men) if man[0] == m)
        w = men[m_idx][1][men[m_idx][2]]

        propose(men, m)
        w_idx = next(i for i, woman in enumerate(women) if woman[0] == w)
        current_m = women[w_idx][2]

        if current_m is None:
            accept_proposal(women, m, w)
            free_men.pop(0)
        elif prefers(w, m, current_m):
            reject_proposal(men, women, w)
            free_men.append(current_m)
            accept_proposal(women, m, w)
            free_men.pop(0)
        else:
            print(f"{w} rejects proposal from {m}")
            men[m_idx][3] = None

    print("\n--- Final Stable Matching ---")
    for w in women:
        print(f"Woman {w[0]} is matched with Man {w[2]}")

gale_shapley(men, women)
